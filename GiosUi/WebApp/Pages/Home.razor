@page "/"

@inject IJSRuntime JsRuntime

<div id="map" style="height:400px"></div>

<MudDrawer @bind-Open="_open"
           Anchor="Anchor.Bottom"
           Variant="DrawerVariant.Temporary"
           Class="bottom-panel"
           Elevation="10"
           Overlay="true">

    <MudText Typo="Typo.h6">Panel od dołu</MudText>
    <MudText>To jest wysuwany widok.</MudText>

    <MudButton OnClick="() => _open = false">Zamknij</MudButton>
</MudDrawer>

