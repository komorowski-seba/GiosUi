@inherits LayoutComponentBase

<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>

    <MudAppBar Elevation="4" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-2">ERP System</MudText>

        <MudSpacer />

        <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit" />
        <MudMenu Icon="@Icons.Material.Filled.AccountCircle">
            <MudMenuItem>Profil</MudMenuItem>
            <MudMenuItem>Wyloguj</MudMenuItem>
        </MudMenu>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Variant="DrawerVariant.Responsive"
               Elevation="4"
               Anchor="Anchor.Start"
               Class="mud-theme-background">

        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All">
                <MudIcon Icon="@Icons.Material.Filled.Map" />
                Mapa stacji
            </MudNavLink>

            <MudNavLink Href="/StationsList">
                <MudIcon Icon="@Icons.Material.Filled.List" />
                Lista stacji
            </MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent >
        @Body
    </MudMainContent>

</MudLayout>

@code {
    private bool _drawerOpen = true;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }
}