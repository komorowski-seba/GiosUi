@code {
    private DotNetObjectReference<Home>? _objRef;

    private bool _open;

    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _objRef = DotNetObjectReference.Create(this);
            
            await JsRuntime.InvokeVoidAsync("initLeafletMap", 52.2297, 21.0122, _objRef);
        }
    }

    [JSInvokable]
    public void OnMarkClicked(double lat, double lng)
    {
        Console.WriteLine($"Kliknięto marker: {lat}, {lng}");
    }
    
    public void Dispose()
    {
        _objRef?.Dispose();
    }
}